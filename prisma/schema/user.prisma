model User {
    id           String    @id @default(uuid())
    name         String    @db.VarChar(255)
    email        String    @unique
    password     String
    activeStatus Status    @default(Active)
    role         Role      @default(User)
    profile      Profile?
    post         Post[]
    comments     Comment[]
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    @@map("user")
}
